{
  "name": "grain",
  "version": "0.2.0",
  "description": "Self-improving AI coding agent with persistent memory",
  "keywords": ["ai", "agent", "coding", "llm", "bedrock", "anthropic", "knowledge-graph"],
  "author": "Stephen Keehn <stephen@skeehn.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
