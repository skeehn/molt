  },
  "bugs": {
    "url": "https://github.com/skeehn/grain/issues"
  },
  "homepage": "https://github.com/skeehn/grain#readme",
  "type": "module",
  "bin": {
    "grain": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "latest",
    "@anthropic-ai/sdk": "latest",
    "@aws-sdk/client-bedrock-runtime": "latest",
    "@types/react": "^19.2.17",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "ink": "^7.1.0",
    "ora": "^9.4.1",
    "react": "^19.2.7",
    "signal-exit": "^4.1.0",
    "standardwebhooks": "^1.0.0",
    "vscode-languageclient": "^10.0.1",
    "vscode-languageserver-protocol": "^3.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "bun-types": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
