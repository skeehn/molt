        const matchedKeywords = skill.pattern.keywords.filter((kw) => inputLower.includes(kw.toLowerCase()));
        if (matchedKeywords.length > 0) {
          const confidence = Math.min(0.95, 0.7 + matchedKeywords.length / skill.pattern.keywords.length * 0.25);
          matches.push({
            skill,
            confidence,
            trigger: "keyword",
            matched: matchedKeywords.join(", ")
