    for (const skill of this.skills.values()) {
      if (skill.pattern.regex) {
        for (const pattern of skill.pattern.regex) {
          try {
            const regex2 = new RegExp(pattern, "i");
            if (regex2.test(input)) {
              matches.push({
                skill,
                confidence: 0.9,
