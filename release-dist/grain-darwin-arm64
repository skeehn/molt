    for (const block of msg.content) {
      if (block.type === "text")
        chars += block.text.length;
      else if (block.type === "tool_result")
        chars += block.content.length;
      else if (block.type === "tool_use")
        chars += JSON.stringify(block.input).length + block.name.length;
